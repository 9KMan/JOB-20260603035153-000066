# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-to-a-50-character-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL on AWS RDS)
DATABASE_URL=postgres://fdd_user:change-me@fdd-prod.cluster-xxxxx.us-east-1.rds.amazonaws.com:5432/fdd
DB_SSLMODE=require

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=fdd-prod-uploads
AWS_S3_REGION_NAME=us-east-1

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# Email (for error notifications)
SENTRY_DSN=
DEFAULT_FROM_EMAIL=platform@fdd.example.com

# ETL behaviour
ETL_BATCH_SIZE=5000
ETL_STAGING_DIR=/var/lib/fdd/staging
